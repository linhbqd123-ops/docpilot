{
    "name": "docpilot-frontend",
    "version": "1.0.0",
    "description": "DocPilot Word Add-in Frontend",
    "scripts": {
        "start": "npx office-addin-debugging start manifest.xml",
        "dev": "npx http-server . -p 3000 -S -C certs/localhost.crt -K certs/localhost.key --cors",
        "dev-http": "npx http-server . -p 3000 --cors",
        "stop": "npx office-addin-debugging stop manifest.xml",
        "sideload": "npx office-addin-dev-certs install && npx office-toolbox sideload -m manifest.xml -a word"
    },
    "devDependencies": {
        "http-server": "^14.1.1",
        "office-addin-debugging": "^5.1.0",
        "office-addin-dev-certs": "^1.13.0"
    }
}
