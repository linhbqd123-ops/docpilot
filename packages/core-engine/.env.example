# ─── Doc MCP (Java service — internal) ─────────────────────────────────────
DOC_MCP_URL=http://localhost:8080

# ─── Local chat persistence ────────────────────────────────────────────────
CHAT_DATABASE_PATH=./data/docpilot.db
LEGACY_CHATS_PATH=./data/chats.json

# ─── Ollama (default local LLM) ────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2

# ─── OpenAI ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o

# ─── Groq (fast inference, OpenAI-compatible) ──────────────────────────────
GROQ_API_KEY=
GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile

# ─── OpenRouter (unified gateway, 300+ models) ─────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=meta-llama/llama-3.3-70b-instruct

# ─── TogetherAI ────────────────────────────────────────────────────────────
TOGETHER_API_KEY=
TOGETHER_DEFAULT_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo

# ─── z.ai ──────────────────────────────────────────────────────────────────
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/v1
ZAI_DEFAULT_MODEL=zai-v1

# ─── Anthropic (own SDK — Messages API) ────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-3-5-sonnet-20241022

# ─── Azure OpenAI (own SDK — different auth) ───────────────────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ─── Custom (any OpenAI-compatible endpoint) ───────────────────────────────
CUSTOM_BASE_URL=
CUSTOM_API_KEY=
CUSTOM_DEFAULT_MODEL=

# ─── Processing limits ─────────────────────────────────────────────────────
REQUEST_TIMEOUT_SECONDS=120
