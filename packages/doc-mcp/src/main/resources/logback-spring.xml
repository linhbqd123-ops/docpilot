<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <springProperty scope="context" name="docMcpLogFile" source="LOG_FILE" defaultValue="debug/doc-mcp.log"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>INFO</level>
        </filter>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] [%X{docpilotTraceId:-no-trace}] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${docMcpLogFile}</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${docMcpLogFile}.%d{yyyy-MM-dd}.%i.gz</fileNamePattern>
            <maxFileSize>25MB</maxFileSize>
            <maxHistory>7</maxHistory>
            <totalSizeCap>250MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] [%X{docpilotTraceId:-no-trace}] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <logger name="io.docpilot.mcp" level="DEBUG"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>
</configuration>