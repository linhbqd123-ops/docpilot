# .env.example — DocPilot doc-mcp
# Generated from src/main/resources/application.yml
# Copy this file to .env and adjust values for your environment

# Server
DOC_MCP_PORT=8080
LOG_FILE=debug/doc-mcp.log

# Multipart upload sizes
MAX_FILE_SIZE=100MB
MAX_REQUEST_SIZE=110MB

# Storage paths (defaults use user home)
DOC_MCP_DATA_DIR=${HOME}/.docpilot/doc-mcp
UPLOAD_DIR=${DOC_MCP_DATA_DIR}/uploads
REGISTRY_DIR=${DOC_MCP_DATA_DIR}/legacy-json/registries
SESSIONS_DIR=${DOC_MCP_DATA_DIR}/legacy-json/sessions
REVISIONS_DIR=${DOC_MCP_DATA_DIR}/legacy-json/revisions
LEGACY_ARCHIVE_DIR=${DOC_MCP_DATA_DIR}/legacy-archive

# SQLite / persistence
SQLITE_PATH=${DOC_MCP_DATA_DIR}/doc-mcp.db
SQLITE_POOL_SIZE=4
SQLITE_BUSY_TIMEOUT_MS=5000
SQLITE_MMAP_SIZE_BYTES=268435456
SQLITE_CACHE_SIZE_KB=32768
SQLITE_WAL_AUTOCHECKPOINT_PAGES=1000
SQLITE_JOURNAL_SIZE_LIMIT_BYTES=67108864
SQLITE_MIGRATE_LEGACY_JSON=true
SQLITE_ARCHIVE_LEGACY_JSON=true
SQLITE_OPTIMIZE_ON_STARTUP=true

# Personalization / embeddings
PERSONALIZATION_PROVIDER=disabled
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=docpilot_personalization
EMBEDDING_DIMENSIONS=1536
QDRANT_API_KEY=
EMBEDDING_PROVIDER=hashing
EMBEDDING_API_URL=
EMBEDDING_MODEL=
EMBEDDING_API_KEY=
PERSONALIZATION_REQUEST_TIMEOUT_MS=15000
PERSONALIZATION_MAX_SEARCH_RESULTS=8
PERSONALIZATION_MAX_INDEXED_CHARS=1200

# Processing
MAX_FILE_SIZE_BYTES=104857600
EMBED_IMAGES=true

# MCP info (static defaults from application.yml)
MCP_SERVER_NAME=doc-mcp
MCP_SERVER_VERSION=2.0.0
MCP_PROTOCOL_VERSION=2024-11-05
