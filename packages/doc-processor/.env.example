# DocPilot Doc Processor — Environment Variables
# Copy this to .env and adjust values as needed.
# The service also works without this file — all variables have defaults.

# Port the service listens on
DOC_PROCESSOR_PORT=8080

# File size limits (applied to Spring multipart and processing validation)
MAX_FILE_SIZE=100MB
MAX_REQUEST_SIZE=110MB
MAX_FILE_SIZE_BYTES=104857600

# Storage directories (absolute paths; created automatically if they don't exist)
UPLOAD_DIR=./data/uploads
REGISTRY_DIR=./data/registries

# Whether to embed images as base64 inside the HTML output,
# or write them to disk (useful for very large docs)
EMBED_IMAGES=true

# Log file path
LOG_FILE=./logs/doc-processor.log
