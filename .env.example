# ===== Agent Backend =====
AGENT_HOST=0.0.0.0
AGENT_PORT=8000
# For Docker: http://doc-mcp:8001/api/v1 | For local: http://localhost:8001/api/v1
AGENT_DOC_MCP_URL=http://localhost:8001/api/v1
# For Docker: /app/config/llm_config.json | For local: leave empty (auto-detected)
AGENT_LLM_CONFIG_PATH=
AGENT_MAX_AGENT_STEPS=10

# ===== DOC-MCP Service =====
DOC_MCP_HOST=0.0.0.0
DOC_MCP_PORT=8001
DOC_MCP_MAX_FILE_SIZE_MB=50

# ===== LLM Provider API Keys =====
# Set these for cloud providers (leave empty for local-only)
LLM_PROVIDER_GROQ_API_KEY=
LLM_PROVIDER_OPENROUTER_API_KEY=
LLM_PROVIDER_OPENAI_API_KEY=

# ===== LLM SSL Configuration =====
# Disable SSL verification in development environments with self-signed certificates
# Set to 'true' in production for security
LLM_VERIFY_SSL=false

# ===== LLM JSON Strict Mode Configuration =====
# Controls structured outputs strict mode for JSON schema (if provider supports it)
# strict: true  = Guaranteed schema compliance (constrained decoding) - production ready
# strict: false = Best-effort schema validation - for broader model compatibility
# Auto-detection: strict=true for models that support it (gpt-oss-*, llama-4-scout-*)
#                 strict=false for others (llama-3.3-*, etc)
# Set to explicit value to override auto-detection: 'true' or 'false'
LLM_JSON_STRICT=auto
