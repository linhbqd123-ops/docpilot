# ===== Agent Backend =====
AGENT_HOST=0.0.0.0
AGENT_PORT=8000
# For Docker: http://doc-mcp:8001/api/v1 | For local: http://localhost:8001/api/v1
AGENT_DOC_MCP_URL=http://localhost:8001/api/v1
# For Docker: /app/config/llm_config.json | For local: leave empty (auto-detected)
AGENT_LLM_CONFIG_PATH=
AGENT_MAX_AGENT_STEPS=10

# ===== DOC-MCP Service =====
DOC_MCP_HOST=0.0.0.0
DOC_MCP_PORT=8001
DOC_MCP_MAX_FILE_SIZE_MB=50

# ===== LLM Provider API Keys =====
# Set these for cloud providers (leave empty for local-only)
LLM_PROVIDER_GROQ_API_KEY=
LLM_PROVIDER_OPENROUTER_API_KEY=
LLM_PROVIDER_OPENAI_API_KEY=
